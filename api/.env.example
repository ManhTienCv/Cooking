PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=Cooking
DB_PASSWORD=replace-with-strong-db-password
DB_NAME=CookingDB

SESSION_SECRET=replace-with-long-random-secret

# Comma-separated origins for CORS (browser dev server)
CORS_ORIGIN=http://localhost:5173

# Google AI (Gemini) — lấy tại https://aistudio.google.com/apikey
AI_API_KEY=

# CookingWeb — gửi OTP (Gmail: 2FA + App Password)
MAIL_BRAND=CookingWeb
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CookingWeb <your-email@gmail.com>

# reCAPTCHA v2 — sau 3 lần đăng nhập sai (user + admin) cần checkbox. Tạo tại https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
