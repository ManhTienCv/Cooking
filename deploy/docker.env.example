# Sao chép thành .env.docker ở thư mục gốc repo rồi chỉnh giá trị.
# Chạy: docker compose --env-file .env.docker up --build

DB_PASSWORD=thay-bang-mat-khau-db-manh
SESSION_SECRET=thay-bang-chuoi-ngau-nhien-dai

# Origin mà trình duyệt dùng khi mở site (Docker mặc định cổng 8080)
CORS_ORIGIN=http://localhost:8080
HTTP_PORT=8080

# reCAPTCHA (build web + runtime API)
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

