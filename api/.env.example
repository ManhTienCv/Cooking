PORT=3001
NODE_ENV=development
# Postgresql
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

SESSION_SECRET=replace-with-long-random-secret

# Comma-separated origins for CORS (browser dev server)
CORS_ORIGIN=http://localhost:5173

# AI
AI_API_KEY=

# CookingWeb — gửi OTP (Gmail: 2FA + App Password)
MAIL_BRAND=CookingWeb
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CookingWeb <your-email@gmail.com>

# reCAPTCHA v2 — sau 3 lần đăng nhập sai (user + admin) cần checkbox. Tạo tại https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
